<mvc:View
    controllerName="com.visitas.visitasui.controller.Visitas"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

    <Page id="page" title="Gestión de Visitas">

        <content>
            <VBox id="vboxMain" class="sapUiSmallMargin" width="100%">

                <Title id="tlDtAu" text="📌 Datos automáticos" level="H2"/>

                <Text id="txtFecha" text="📅 Fecha: no establecida" />
                <Text id="txtHoraInicio" text="⏰ Inicio visita: no registrada" />
                <Text id="txtHoraFin" text="⏰ Fin visita: no registrada" />
                <Text id="txtGPS" text="📍 Ubicación: no obtenida" />

                <HBox id="hbx" class="sapUiSmallMarginTop">

                    <Button
                        id="btnStartVisit"
                        text="▶️ Iniciar visita"
                        type="Accept"
                        press="onStartVisit" />

                    <Button
                        id="btnEndVisit"
                        text="⏹ Finalizar visita"
                        type="Reject"
                        press="onEndVisit" />

                </HBox>

                <Button
                    id="btnDate"
                    text="📅 Registrar fecha"
                    press="onSetDate" />

                <Button
                    id="btnLocation"
                    text="📍 Obtener ubicación"
                    press="onGetLocation" />

                <Label id="lblEspacio1" text="" />

                <Title id="tlDtEmp" text="🏢 Datos de la empresa" level="H2"/>

                <Label id="lbEmp" text="Empresa" />
                <Input id="empresa" placeholder="Introduzca nombre de la empresa..." />

                <Label id="lbDir" text="Dirección" />
                <Input id="direccion" placeholder="Introduzca la dirección..." />

                <Label id="lbTelf" text="Teléfono" />
                <Input id="contacto" placeholder="Introduzca número de contacto..." />

                <Label id="lbCorreo" text="Correo electrónico" />
                <Input id="email" placeholder="Introduzca correo de contacto..." />

                <Label id="lbResp" text="Responsable de la visita" />
                <Input id="responsable" placeholder="Introduzca nombre del encargado..." />

                <Label id="lbEmpd" text="Empleado" />
                <Input id="empleado" placeholder="Introduzca nombre del empleado..." />

                <Label id="lbObs" text="Observaciones" />
                <TextArea id="observaciones" placeholder="Introduzca observaciones..." rows="6"/>

                <Label id="lblEspacio2" text="" />

                <Button
                    id="btnSave"
                    text="💾 Guardar visita"
                    type="Emphasized"
                    press="onSave" />

                <Button
                    id="btnAdmin"
                    text="📊 Registro de visitas"
                    press="onNavAdmin" />

            </VBox>
        </content>
    </Page>
</mvc:View>