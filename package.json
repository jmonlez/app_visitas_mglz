{
  "name": "app_visitas",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "@sap/ux-ui5-tooling": "^1.24.0"
  },
  "scripts": {
    "start": "cds-serve"
  },
  "private": true,
  "cds": {
    "requires": {
      "auth": "mocked",
      "db": {
        "kind": "hana"
      }
    },
    "build": {
      "tasks": [
        {
          "for": "hana",
          "src": "db"
        },
        {
          "for": "nodejs",
          "src": "srv"
        }
      ]
    }
  }
}
